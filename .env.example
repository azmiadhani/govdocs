# Database
DATABASE_URL=postgres://user:password@localhost:5432/govdocs
DB_HOST=localhost
DB_PORT=5432
DB_NAME=govdocs
DB_USER=postgres
DB_PASS=password

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Redis (Upstash or self-hosted)
REDIS_URL=redis://localhost:6379

# File Storage
# Local dev:
STORAGE_PATH=./uploads
# Production S3-compatible:
# AWS_BUCKET=govdocs-files
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=

NODE_ENV=development
